<Window x:Class="WpfCrud.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="SQLite CRUD" Height="520" Width="700"
        Background="#1E1E2E" FontFamily="Segoe UI" WindowStartupLocation="CenterScreen">

    <Window.Resources>

        <!-- Placeholder helper: Tag holds the hint text -->
        <Style x:Key="PlaceholderBox" TargetType="TextBox">
            <Setter Property="Background" Value="#12121F"/>
            <Setter Property="Foreground" Value="#E0E0F0"/>
            <Setter Property="BorderBrush" Value="#3A3A5C"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding" Value="8,6"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="CaretBrush" Value="#7B7BFF"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="TextBox">
                        <Border Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}">
                            <Grid>
                                <ScrollViewer x:Name="PART_ContentHost"
                                              Padding="{TemplateBinding Padding}"
                                              VerticalAlignment="Center"/>
                                <TextBlock x:Name="Placeholder"
                                           Text="{TemplateBinding Tag}"
                                           Foreground="#505070"
                                           FontSize="{TemplateBinding FontSize}"
                                           Margin="{TemplateBinding Padding}"
                                           VerticalAlignment="Center"
                                           IsHitTestVisible="False"
                                           Visibility="Collapsed"/>
                            </Grid>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="Text" Value="">
                                <Setter TargetName="Placeholder" Property="Visibility" Value="Visible"/>
                            </Trigger>
                            <Trigger Property="IsFocused" Value="True">
                                <Setter Property="BorderBrush" Value="#7B7BFF"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="CardPanel" TargetType="Border">
            <Setter Property="Background" Value="#2A2A3E"/>
            <Setter Property="CornerRadius" Value="8"/>
            <Setter Property="Padding" Value="16"/>
        </Style>

        <Style x:Key="Label" TargetType="TextBlock">
            <Setter Property="Foreground" Value="#A0A0C0"/>
            <Setter Property="FontSize" Value="11"/>
            <Setter Property="Margin" Value="0,0,0,4"/>
        </Style>

        <Style x:Key="PrimaryBtn" TargetType="Button">
            <Setter Property="Background" Value="#7B7BFF"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Padding" Value="16,8"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}" CornerRadius="6"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Background" Value="#9090FF"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter Property="Background" Value="#6060E0"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="DangerBtn" TargetType="Button" BasedOn="{StaticResource PrimaryBtn}">
            <Setter Property="Background" Value="#E05555"/>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#F07070"/>
                </Trigger>
                <Trigger Property="IsPressed" Value="True">
                    <Setter Property="Background" Value="#C03030"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <Style x:Key="SecondaryBtn" TargetType="Button" BasedOn="{StaticResource PrimaryBtn}">
            <Setter Property="Background" Value="#3A3A5C"/>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#4A4A70"/>
                </Trigger>
            </Style.Triggers>
        </Style>
    </Window.Resources>

    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Header -->
        <StackPanel Grid.Row="0" Margin="0,0,0,16">
            <TextBlock Text="📋 Contact Manager" FontSize="22" FontWeight="Bold"
                       Foreground="#E0E0F0"/>
            <TextBlock x:Name="StatusText" Text="Ready" FontSize="11"
                       Foreground="#6060A0" Margin="0,2,0,0"/>
        </StackPanel>

        <!-- Form -->
        <Border Grid.Row="1" Style="{StaticResource CardPanel}" Margin="0,0,0,16">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <TextBlock Grid.Column="0" Grid.Row="0" Text="NAME" Style="{StaticResource Label}"/>
                <TextBlock Grid.Column="1" Grid.Row="0" Text="EMAIL" Style="{StaticResource Label}" Margin="8,0,0,4"/>
                <TextBlock Grid.Column="2" Grid.Row="0" Text="PHONE" Style="{StaticResource Label}" Margin="8,0,0,4"/>

                <!-- Tag = placeholder text -->
                <TextBox x:Name="NameBox"  Grid.Column="0" Grid.Row="1"
                         Style="{StaticResource PlaceholderBox}" Tag="John Doe"/>
                <TextBox x:Name="EmailBox" Grid.Column="1" Grid.Row="1"
                         Style="{StaticResource PlaceholderBox}" Tag="john@example.com"
                         Margin="8,0,0,0"/>
                <TextBox x:Name="PhoneBox" Grid.Column="2" Grid.Row="1"
                         Style="{StaticResource PlaceholderBox}" Tag="+1 555 0100"
                         Margin="8,0,0,0"/>

                <StackPanel Grid.Column="3" Grid.Row="1" Orientation="Horizontal"
                            VerticalAlignment="Center" Margin="8,0,0,0">
                    <Button x:Name="SaveBtn" Content="💾 Save" Style="{StaticResource PrimaryBtn}"
                            Click="SaveBtn_Click"/>
                    <Button x:Name="ClearBtn" Content="✕" Style="{StaticResource SecondaryBtn}"
                            Margin="6,0,0,0" Width="44" Click="ClearBtn_Click"
                            ToolTip="Clear form"/>
                </StackPanel>

                <TextBox x:Name="IdBox" Visibility="Collapsed"/>
            </Grid>
        </Border>

        <!-- Data Grid -->
        <Border Grid.Row="2" Style="{StaticResource CardPanel}">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>

                <Grid Grid.Row="0" Margin="0,0,0,10">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <TextBox x:Name="SearchBox"
                             Style="{StaticResource PlaceholderBox}"
                             Tag="🔍  Search by name or email..."
                             TextChanged="SearchBox_TextChanged"/>
                    <TextBlock x:Name="CountText" Grid.Column="1" VerticalAlignment="Center"
                               Foreground="#6060A0" FontSize="11" Margin="12,0,0,0"/>
                </Grid>

                <DataGrid x:Name="ContactGrid" Grid.Row="1"
                          AutoGenerateColumns="False" IsReadOnly="True"
                          SelectionMode="Single" SelectionUnit="FullRow"
                          Background="#12121F" Foreground="#D0D0F0"
                          BorderThickness="0" GridLinesVisibility="Horizontal"
                          HorizontalGridLinesBrush="#2A2A3E"
                          RowBackground="#12121F" AlternatingRowBackground="#181828"
                          ColumnHeaderHeight="36"
                          SelectionChanged="ContactGrid_SelectionChanged">

                    <DataGrid.ColumnHeaderStyle>
                        <Style TargetType="DataGridColumnHeader">
                            <Setter Property="Background" Value="#1E1E2E"/>
                            <Setter Property="Foreground" Value="#7B7BFF"/>
                            <Setter Property="FontSize" Value="11"/>
                            <Setter Property="FontWeight" Value="Bold"/>
                            <Setter Property="Padding" Value="12,0"/>
                            <Setter Property="BorderThickness" Value="0"/>
                        </Style>
                    </DataGrid.ColumnHeaderStyle>

                    <DataGrid.RowStyle>
                        <Style TargetType="DataGridRow">
                            <Style.Triggers>
                                <Trigger Property="IsSelected" Value="True">
                                    <Setter Property="Background" Value="#2A2A5C"/>
                                </Trigger>
                                <Trigger Property="IsMouseOver" Value="True">
                                    <Setter Property="Background" Value="#22223A"/>
                                </Trigger>
                            </Style.Triggers>
                        </Style>
                    </DataGrid.RowStyle>

                    <DataGrid.CellStyle>
                        <Style TargetType="DataGridCell">
                            <Setter Property="BorderThickness" Value="0"/>
                            <Setter Property="Padding" Value="12,8"/>
                            <Setter Property="Template">
                                <Setter.Value>
                                    <ControlTemplate TargetType="DataGridCell">
                                        <Border Padding="{TemplateBinding Padding}"
                                                Background="{TemplateBinding Background}">
                                            <ContentPresenter VerticalAlignment="Center"/>
                                        </Border>
                                    </ControlTemplate>
                                </Setter.Value>
                            </Setter>
                            <Style.Triggers>
                                <Trigger Property="IsSelected" Value="True">
                                    <Setter Property="Foreground" Value="White"/>
                                </Trigger>
                            </Style.Triggers>
                        </Style>
                    </DataGrid.CellStyle>

                    <DataGrid.Columns>
                        <DataGridTextColumn Header="ID"      Binding="{Binding Id}"        Width="50"/>
                        <DataGridTextColumn Header="NAME"    Binding="{Binding Name}"      Width="*"/>
                        <DataGridTextColumn Header="EMAIL"   Binding="{Binding Email}"     Width="*"/>
                        <DataGridTextColumn Header="PHONE"   Binding="{Binding Phone}"     Width="130"/>
                        <!-- FIX: StringFormat must use {} escape inside attribute syntax -->
                        <DataGridTextColumn Header="CREATED"
                                            Binding="{Binding CreatedAt, StringFormat='MMM dd, yyyy'}"
                                            Width="110"/>
                    </DataGrid.Columns>
                </DataGrid>
            </Grid>
        </Border>

        <!-- Footer actions -->
        <StackPanel Grid.Row="3" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,12,0,0">
            <Button x:Name="EditBtn"   Content="✏️ Edit Selected"   Style="{StaticResource SecondaryBtn}"
                    Click="EditBtn_Click"   IsEnabled="False" Margin="0,0,8,0"/>
            <Button x:Name="DeleteBtn" Content="🗑 Delete Selected" Style="{StaticResource DangerBtn}"
                    Click="DeleteBtn_Click" IsEnabled="False"/>
        </StackPanel>
    </Grid>
</Window>
